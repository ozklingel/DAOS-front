{
  "info": {
    "_postman_id": "a1b2c3d4-daos-api-2026",
    "name": "DAOS API",
    "description": "Postman collection for the DAOS / TaskMail FastAPI backend.\n\nQuick start:\n1. Set `baseUrl` (local: http://127.0.0.1:8080 or production: https://daos-api.onrender.com)\n2. Run **Auth → Dev Login** — scripts save `accessToken` / `refreshToken`\n3. Other requests use Bearer `{{accessToken}}` automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8080" },
    { "key": "apiPrefix", "value": "/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "connectionId", "value": "" },
    { "key": "documentId", "value": "" },
    { "key": "assetId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Public liveness probe. Includes openai_configured flag."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Dev Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', j.access_token || j.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', j.refresh_token || j.refreshToken || '');",
                  "  pm.test('Saved tokens', () => pm.expect(pm.collectionVariables.get('accessToken')).to.be.ok);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}{{apiPrefix}}/auth/dev",
            "description": "Local/dev sign-in. Saves access + refresh tokens to collection variables."
          }
        },
        {
          "name": "Google Sign-In",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"GOOGLE_ID_TOKEN\",\n  \"accessToken\": null,\n  \"serverAuthCode\": null\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/google"
          }
        },
        {
          "name": "Outlook Sign-In",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"MICROSOFT_ACCESS_TOKEN\",\n  \"refreshToken\": \"MICROSOFT_REFRESH_TOKEN\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/outlook"
          }
        },
        {
          "name": "Outlook Authorize URL",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"redirectUri\": \"http://127.0.0.1:5173/oauth/outlook\",\n  \"state\": \"postman-state\",\n  \"codeChallenge\": \"CODE_CHALLENGE_S256\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/outlook/authorize-url"
          }
        },
        {
          "name": "Outlook Exchange Code",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"AUTH_CODE\",\n  \"redirectUri\": \"http://127.0.0.1:5173/oauth/outlook\",\n  \"codeVerifier\": \"CODE_VERIFIER\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/outlook/exchange"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', j.access_token || j.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', j.refresh_token || j.refreshToken || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/refresh"
          }
        },
