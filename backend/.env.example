# TaskMail Backend Environment Variables

APP_NAME=TaskMail API
DEBUG=true
API_PREFIX=/api/v1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./taskmail.db
# DATABASE_URL=postgresql://taskmail:taskmail@localhost:5432/taskmail

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth (must match mobile app client IDs)
# Web client ID + secret — used for Gmail server auth code exchange and ID token verification
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
# Optional: Android OAuth client ID if ID tokens are issued for the mobile client
GOOGLE_ANDROID_CLIENT_ID=
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=

# OpenAI (optional — falls back to heuristics if empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Firebase (optional — for push notifications)
FIREBASE_CREDENTIALS_PATH=

# CORS
CORS_ORIGINS=*

# Background jobs
EMAIL_SYNC_INTERVAL_MINUTES=15

# WhatsApp Cloud API (optional — voice/text → task)
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=1281218281733444
WHATSAPP_APP_SECRET=
